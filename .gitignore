# ---- Unity generated / machine-specific (never commit these) ----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta files must travel with their asset, so don't ignore them
!/[Aa]ssets/**/*.meta

# ---- IDE / tooling (auto-generated by Unity) ----
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ---- Builds / packages ----
*.apk
*.aab
*.unitypackage
*.app
sysinfo.txt
crashlytics-build.properties

# ---- OS noise ----
.DS_Store
.DS_Store?
._*
Thumbs.db

# ---- Misc local backups ----
*.bak

# ---- Leftover Unity tutorial videos (template content, not part of the game) ----
# Excluded from the repo to keep it lean; the files remain on disk locally.
Assets/Tutorials/Media/

# ---- Android build artifacts Unity drops next to the APK ----
*_BackUpThisFolder_ButDontShipItWithYourGame/
*_BurstDebugInformation_DoNotShip/
.utmp/
